<xs:schema xmlns="http://schemas.nav.gov.hu/EAR/2.0/data"
           xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:common="http://schemas.nav.gov.hu/NTCA/1.0/common"
           xmlns:earbase="http://schemas.nav.gov.hu/EAR/2.0/base"
           targetNamespace="http://schemas.nav.gov.hu/EAR/2.0/data" elementFormDefault="qualified"
           attributeFormDefault="unqualified">
    <xs:import namespace="http://schemas.nav.gov.hu/NTCA/1.0/common"/>
    <xs:import namespace="http://schemas.nav.gov.hu/EAR/2.0/base"/>
    <xs:complexType name="AdditionalAttachmentInfoType">
        <xs:annotation>
            <xs:documentation xml:lang="hu">Csatolmány egyéb adatai</xs:documentation>
            <xs:documentation xml:lang="en">Additional data of the attachment</xs:documentation>
        </xs:annotation>
        <xs:choice>
            <xs:element name="factoringContractData" type="FactoringContractDataType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Faktorálási szerződés adatai</xs:documentation>
                    <xs:documentation xml:lang="en">Factoring contract data</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:choice>
    </xs:complexType>
    <xs:complexType name="AgriculturalCompensationPremiumType">
        <xs:annotation>
            <xs:documentation xml:lang="hu">Mezőgazdasági kompenzációs felár</xs:documentation>
            <xs:documentation xml:lang="en">Agricultural compensation premium</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="sevenPercentCount" type="earbase:BevfeldThreeDigitNumberType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">7%-os mértékű kompenzáció darabszáma</xs:documentation>
                    <xs:documentation xml:lang="en">Count of compensations at 7%</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="twelvePercentCount" type="earbase:BevfeldThreeDigitNumberType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">12%-os mértékű kompenzáció darabszáma</xs:documentation>
                    <xs:documentation xml:lang="en">Count of compensations at 12%</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="AttachmentType">
        <xs:annotation>
            <xs:documentation xml:lang="hu">Csatolmányok</xs:documentation>
            <xs:documentation xml:lang="en">Attachments</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="claimCheckId" type="common:EntityIdType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">A melléklet feltöltésekor kapott azonosító</xs:documentation>
                    <xs:documentation xml:lang="en">Identifier received when uploading the attachment</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="attachmentCategory" type="earbase:AttachmentCategoryType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Csatolmány típus</xs:documentation>
                    <xs:documentation xml:lang="en">Attachment type</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="additionalAttachmentInfo" type="AdditionalAttachmentInfoType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Csatolmány egyéb adatai</xs:documentation>
                    <xs:documentation xml:lang="en">Additional data of the attachment</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="DeclarationStatementsType">
        <xs:annotation>
            <xs:documentation xml:lang="hu">Nyilatkozatok</xs:documentation>
            <xs:documentation xml:lang="en">Statements</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="returnDecision" type="earbase:ReturnDecisionType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Visszautalási döntés</xs:documentation>
                    <xs:documentation xml:lang="en">Return decision</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="taxpayerStatusCode" type="earbase:TaxpayerStatusCodeType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Adózói státusz</xs:documentation>
                    <xs:documentation xml:lang="en">Taxpayer status</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="procedureStatements" type="ProcedureStatementsType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Eljárási nyilatkozatok</xs:documentation>
                    <xs:documentation xml:lang="en">Statements of procedures</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="returnStatements" type="ReturnStatementsType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Visszautalási nyilatkozatok</xs:documentation>
                    <xs:documentation xml:lang="en">Return statements</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="DeclarationSummaryType">
        <xs:annotation>
            <xs:documentation xml:lang="hu">A bevallás összegző adatai</xs:documentation>
            <xs:documentation xml:lang="en">Summary data of the declaration</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="SummaryType">
                <xs:sequence>
                    <xs:element name="lapsedResidualTaxIndicator" type="xs:boolean" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation xml:lang="hu">Előző időszakról beszámítható csökkentő tétel összege
                                elévült követelést tartalmaz
                            </xs:documentation>
                            <xs:documentation xml:lang="en">Amount of deduction from previous period includes lapsed
                                receivables
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>
    <xs:complexType name="DeductionOptionsType">
        <xs:annotation>
            <xs:documentation xml:lang="hu">Levonási adatok</xs:documentation>
            <xs:documentation xml:lang="en">Deduction data</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="deductionRate" type="earbase:TaxRateType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Levonási hányados</xs:documentation>
                    <xs:documentation xml:lang="en">Deduction rate</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="deductionAmount" type="earbase:TaxMonetaryType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Levonási összeg</xs:documentation>
                    <xs:documentation xml:lang="en">Deduction amount</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="DomesticPaymentServiceProviderType">
        <xs:annotation>
            <xs:documentation xml:lang="hu">Belföldi pénzügyi szolgáltató adatai</xs:documentation>
            <xs:documentation xml:lang="en">Domestic payment service provider data</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="domesticProviderName" type="earbase:BevfeldText80Type">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Belföldi szolgáltató neve</xs:documentation>
                    <xs:documentation xml:lang="en">Domestic service provider name</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="domesticBankAccountNumber" type="common:BankAccountNumberType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Belföldi számlaszám</xs:documentation>
                    <xs:documentation xml:lang="en">Domestic bank account number</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="DomesticTaxDataType">
        <xs:annotation>
            <xs:documentation xml:lang="hu">Belföldi adószám adatok</xs:documentation>
            <xs:documentation xml:lang="en">Domestic tax number data</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="taxNumber" type="common:TaxpayerIdType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Az adószám 8 jegyű törzsszáma</xs:documentation>
                    <xs:documentation xml:lang="en">The 8-digit core number section of the tax number</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="groupMemberTaxNumber" type="common:TaxpayerIdType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Csoport tag adószámának 8 jegyű törzsszáma</xs:documentation>
                    <xs:documentation xml:lang="en">The 8-digit core number section of the group member's tax number
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="FactoringContractDataType">
        <xs:annotation>
            <xs:documentation xml:lang="hu">Faktorálási szerződés adatai</xs:documentation>
            <xs:documentation xml:lang="en">Factoring contract data</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="factoringContractNumber" type="earbase:BevfeldText40Type">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Faktorálási szerződés száma</xs:documentation>
                    <xs:documentation xml:lang="en">Factoring contract number</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="factoringContractDate" type="earbase:DeclarationBaseDateType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Faktorálási szerződés kelte</xs:documentation>
                    <xs:documentation xml:lang="en">Factoring contract date</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="factoringTaxCode" type="earbase:FactoringTaxCodeType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Adónem</xs:documentation>
                    <xs:documentation xml:lang="en">Tax code</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="factoringAmount" type="earbase:TaxMonetaryType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Faktorált összeg</xs:documentation>
                    <xs:documentation xml:lang="en">Factoring amount</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:choice>
                <xs:element name="domesticPaymentServiceProvider" type="DomesticPaymentServiceProviderType">
                    <xs:annotation>
                        <xs:documentation xml:lang="hu">Belföldi pénzügyi szolgáltató adatai</xs:documentation>
                        <xs:documentation xml:lang="en">Domestic payment service provider data</xs:documentation>
                    </xs:annotation>
                </xs:element>
                <xs:element name="foreignPaymentServiceProvider" type="ForeignPaymentServiceProviderType">
                    <xs:annotation>
                        <xs:documentation xml:lang="hu">Külföldi pénzügyi szolgáltató adatai</xs:documentation>
                        <xs:documentation xml:lang="en">Foreign payment service provider data</xs:documentation>
                    </xs:annotation>
                </xs:element>
            </xs:choice>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="ForeignPaymentServiceProviderType">
        <xs:annotation>
            <xs:documentation xml:lang="hu">Külföldi pénzügyi szolgáltató adatai</xs:documentation>
            <xs:documentation xml:lang="en">Foreign payment service provider data</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="foreignProviderName" type="earbase:BevfeldText80Type">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Külföldi pénzügyi szolgáltató neve</xs:documentation>
                    <xs:documentation xml:lang="en">Foreign payment service provider name</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="foreignProviderAddress" type="earbase:BevfeldText80Type">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Külföldi pénzügyi szolgáltató címe</xs:documentation>
                    <xs:documentation xml:lang="en">Foreign payment service provider address</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="foreignBankAccountOwnerName" type="earbase:BevfeldText80Type">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Külföldi számla tulajdonosának neve</xs:documentation>
                    <xs:documentation xml:lang="en">Foreign bank account owner's name</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="foreignBankAccountNumber" type="earbase:BevfeldForeignAccountType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Külföldi számla száma</xs:documentation>
                    <xs:documentation xml:lang="en">Foreign bank account number</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ibanIndicator" type="xs:boolean">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">IBAN számlaszám jelölés</xs:documentation>
                    <xs:documentation xml:lang="en">IBAN account number indication</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="swiftCode" type="common:SwiftCodeType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">SWIFT kód</xs:documentation>
                    <xs:documentation xml:lang="en">SWIFT code</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="countryCode" type="common:CountryCodeType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Országkód</xs:documentation>
                    <xs:documentation xml:lang="en">Country code</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="currencyCode" type="common:CurrencyType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">A számla pénzneme az ISO 4217 szabvány szerint</xs:documentation>
                    <xs:documentation xml:lang="en">ISO 4217 currency code on the invoice</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="GeneralLedgerInformationType">
        <xs:annotation>
            <xs:documentation xml:lang="hu">Főkönyvi adatok</xs:documentation>
            <xs:documentation xml:lang="en">General ledger data</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="glAccountId" type="common:SimpleText512NotBlankType" maxOccurs="2">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Főkönyvi számlaszám</xs:documentation>
                    <xs:documentation xml:lang="en">General ledger account number</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="glPostingDate" type="earbase:TaxpointDateType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Főkönyvi feladás dátuma</xs:documentation>
                    <xs:documentation xml:lang="en">General ledger posting date</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="glTransactionId" type="common:SimpleText512NotBlankType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Főkönyvi könyvelés egyedi azonosítója</xs:documentation>
                    <xs:documentation xml:lang="en">Unique identifier for general ledger accounting</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="PartnerInfoType">
        <xs:annotation>
            <xs:documentation xml:lang="hu">Partner adatok</xs:documentation>
            <xs:documentation xml:lang="en">Partner data</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="partnerStatus" type="earbase:PartnerStatusType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Partner ÁFA szerinti státusza</xs:documentation>
                    <xs:documentation xml:lang="en">Partner's VAT-related status</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="partnerTaxData" type="PartnerTaxDataType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Partner adószáma</xs:documentation>
                    <xs:documentation xml:lang="en">Partner's tax number</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="partnerName" type="common:SimpleText512NotBlankType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Partner neve</xs:documentation>
                    <xs:documentation xml:lang="en">Partner's name</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="partnerAddress" type="earbase:AddressType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Partner címadatai</xs:documentation>
                    <xs:documentation xml:lang="en">Partner's address</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="PartnerTaxDataType">
        <xs:annotation>
            <xs:documentation xml:lang="hu">Partner adószáma</xs:documentation>
            <xs:documentation xml:lang="en">Partner's tax number</xs:documentation>
        </xs:annotation>
        <xs:choice>
            <xs:element name="domesticTaxData" type="DomesticTaxDataType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Belföldi adószám adatok</xs:documentation>
                    <xs:documentation xml:lang="en">Domestic tax number data</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="communityVatNumber" type="common:CommunityVatNumberType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Közösségi adószám</xs:documentation>
                    <xs:documentation xml:lang="en">Community tax number</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="thirdStateTaxId" type="common:SimpleText50NotBlankType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Harmadik országbeli adóazonosító</xs:documentation>
                    <xs:documentation xml:lang="en">Third state tax identification number</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:choice>
    </xs:complexType>
    <xs:complexType name="PostalReturnType">
        <xs:annotation>
            <xs:documentation xml:lang="hu">Postai kiutalás adatai</xs:documentation>
            <xs:documentation xml:lang="en">Postal return data</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="postalCode" type="earbase:BevfeldPostalCodeType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Irányítószám</xs:documentation>
                    <xs:documentation xml:lang="en">Postal code</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="city" type="earbase:BevfeldCityType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Város</xs:documentation>
                    <xs:documentation xml:lang="en">City</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="additionalAddress" type="earbase:BevfeldAdditionalAddressType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Közterület neve, jellege stb.</xs:documentation>
                    <xs:documentation xml:lang="en">Name and category of public place</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="ProcedureStatementsType">
        <xs:annotation>
            <xs:documentation xml:lang="hu">Eljárási nyilatkozatok</xs:documentation>
            <xs:documentation xml:lang="en">Procedure statements</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="thresholdExceededIndicator" type="xs:boolean">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Küszöbérték túllépés jelölése éves adózó esetén</xs:documentation>
                    <xs:documentation xml:lang="en">Threshold exceeded by annual taxpayer</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="interimFrequencyChangeIndicator" type="xs:boolean">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Adóhatósági engedéllyel évközi gyakoriság váltás jelölése
                    </xs:documentation>
                    <xs:documentation xml:lang="en">Change of frequency with tax authority permit</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="midYearCommunityTaxNumberIndicator" type="xs:boolean">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Közösségi adószám évközi megállapítása miatt törtidőszaki bevallás
                        jelölése éves adózó esetén
                    </xs:documentation>
                    <xs:documentation xml:lang="en">Indication of fractional declaration period because of mid-year
                        assessment of Community tax number
                        for annual taxpayer
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="outOfTurnDeclarationCode" type="earbase:OutOfTurnDeclarationCodeType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Soron kívüli bevallás kódja</xs:documentation>
                    <xs:documentation xml:lang="en">Out-of-turn declaration's code</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="becomesLiveAgainIndicator" type="xs:boolean">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Eljárás végén újra élővé válás jelölése</xs:documentation>
                    <xs:documentation xml:lang="en">Indication of becoming alive again at the end of the procedure
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="animalDiseaseDefermentIndicator" type="xs:boolean">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Állatbetegséggel összefüggő járványügyi intézkedés miatti
                        kártalanítás okán fizetési halasztás
                        kérése
                    </xs:documentation>
                    <xs:documentation xml:lang="en">Request for payment deferral because of compensation due to
                        epidemiological measures related to
                        animal diseases
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="taxLiabilityBesideExemptmentIndicator" type="xs:boolean">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Mentes státusz mellett adókötelezettsége keletkezett
                    </xs:documentation>
                    <xs:documentation xml:lang="en">Tax liability incurred beside exempt status</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="ReturnMethodType">
        <xs:annotation>
            <xs:documentation xml:lang="hu">Visszaigénylés módja</xs:documentation>
            <xs:documentation xml:lang="en">Return method</xs:documentation>
        </xs:annotation>
        <xs:choice>
            <xs:element name="domesticPaymentServiceProvider" type="DomesticPaymentServiceProviderType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Belföldi pénzügyi szolgáltató adatai</xs:documentation>
                    <xs:documentation xml:lang="en">Domestic payment service provider data</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="foreignPaymentServiceProvider" type="ForeignPaymentServiceProviderType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Külföldi pénzügyi szolgáltató adatai</xs:documentation>
                    <xs:documentation xml:lang="en">Foreign payment service provider data</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="postalReturn" type="PostalReturnType">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Postai kiutalás adatai</xs:documentation>
                    <xs:documentation xml:lang="en">Postal return data</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:choice>
    </xs:complexType>
    <xs:complexType name="ReturnStatementsType">
        <xs:annotation>
            <xs:documentation xml:lang="hu">Kiutalási rendelkezések</xs:documentation>
            <xs:documentation xml:lang="en">Return statements</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="returnMethod" type="ReturnMethodType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Visszaigénylés módja</xs:documentation>
                    <xs:documentation xml:lang="en">Return method</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="publicLlcIndicator" type="xs:boolean">
                <xs:annotation>
                    <xs:documentation xml:lang="hu">Nyilvánosan működő részvénytársaság jelölése</xs:documentation>
                    <xs:documentation xml:lang="en">Indication of a public limited company</xs:documentation>
